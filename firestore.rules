rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Sorted pair ID helper — friendships are stored under "{smaller}_{larger}"
    function pairId(a, b) {
      return a < b ? a + '_' + b : b + '_' + a;
    }

    function isFriendOf(userId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/friendships/$(pairId(request.auth.uid, userId)))
        && get(/databases/$(database)/documents/friendships/$(pairId(request.auth.uid, userId))).data.status == 'accepted';
    }

    // User profiles — any authenticated user can read (needed for friend
    // lookup by email and hydrating names in the leaderboard). Only the
    // owner can write their own doc.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      // Workouts — owner has full access; accepted friends can read for the
      // weekly leaderboard.
      match /workouts/{workoutId} {
        allow read: if request.auth != null
          && (request.auth.uid == userId || isFriendOf(userId));
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // AI plans — owner only
      match /plans/{planId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Friendships — either participant can read or delete. Create must be
    // a pending request from the authenticated user. Update is used to flip
    // status to 'accepted'.
    match /friendships/{pairId} {
      allow read, delete: if request.auth != null
        && request.auth.uid in resource.data.users;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.users
        && request.resource.data.users.size() == 2
        && request.resource.data.requesterId == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if request.auth != null
        && request.auth.uid in resource.data.users
        && request.resource.data.status == 'accepted';
    }

    // Analytics events — client-side writes only; never read back from client.
    match /analytics_events/{doc} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
