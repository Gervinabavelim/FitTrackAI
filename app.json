{
  "expo": {
    "name": "FitTrack AI",
    "slug": "fittrack-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fittrackai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "FitTrack AI uses the camera for profile photos.",
        "NSPhotoLibraryUsageDescription": "FitTrack AI uses the photo library for profile photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.fittrackai.app",
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3B82F6",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "FitTrack AI"
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-sharing",
      [
        "expo-build-properties",
        {
          "ios": { "newArchEnabled": true },
          "android": { "newArchEnabled": true }
        }
      ],
      "@sentry/react-native",
      "./plugins/withHealthConnectIntent"
    ],
    "extra": {
      "eas": {
        "projectId": "f9dd5026-b73f-4f2e-aa49-19382c7f5d1a"
      }
    },
    "scheme": "fittrack-ai",
    "owner": "gervin"
  }
}
